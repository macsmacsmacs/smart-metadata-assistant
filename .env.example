# Databricks credentials
# For local dev (PAT): DATABRICKS_HOST, DATABRICKS_TOKEN
# For Cloud Run (OAuth M2M): DATABRICKS_HOST, DATABRICKS_CLIENT_ID, DATABRICKS_CLIENT_SECRET

DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
# PAT (local dev):
# DATABRICKS_TOKEN=your-personal-access-token

# OAuth M2M (production) - store in GCP Secret Manager for Cloud Run:
# DATABRICKS_CLIENT_ID=your-service-principal-client-id
# DATABRICKS_CLIENT_SECRET=your-service-principal-secret

# Optional: SQL warehouse ID (omit to use first available)
# DATABRICKS_WAREHOUSE_ID=

# HTTP mode (set when running as hosted server)
PORT=8080
# MCP_TRANSPORT=http
# HOST=0.0.0.0
